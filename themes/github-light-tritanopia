# +----------------------------------------------------------------------------
# | GitHub Light Tritanopia
# +----------------------------------------------------------------------------
# |
# | Light theme matching the Neovim "github_light_tritanopia" colorscheme
# | (projekt0n/github-nvim-theme) so the terminal and the editor stay in sync.
# | Values extracted verbatim from the plugin's palette/terminal mapping.
# | Used when macOS is in light mode; the dark theme is left untouched.
# |
# +----------------------------------------------------------------------------

# +----------------------------------------------------------------------------
# | ANSI Palette (16 colors)
# +----------------------------------------------------------------------------
# |
# | Indices 0-7 are the normal colors, 8-15 the bright variants, in the order
# | black, red, green, yellow, blue, magenta, cyan, white.
# |
# +----------------------------------------------------------------------------

palette = 0=#24292f
palette = 1=#cf222e
palette = 2=#0550ae
palette = 3=#4d2d00
palette = 4=#0969da
palette = 5=#8250df
palette = 6=#1b7c83
palette = 7=#6e7781
palette = 8=#57606a
palette = 9=#a40e26
palette = 10=#0969da
palette = 11=#633c01
palette = 12=#218bff
palette = 13=#a475f9
palette = 14=#3192aa
palette = 15=#8c959f

# +----------------------------------------------------------------------------
# | Background & Foreground
# +----------------------------------------------------------------------------
# |
# | Base terminal background and default text color.
# |
# +----------------------------------------------------------------------------

background = #ffffff
foreground = #1b1f24

# +----------------------------------------------------------------------------
# | Cursor
# +----------------------------------------------------------------------------
# |
# | Cursor fill color and the color of the glyph under the cursor.
# |
# +----------------------------------------------------------------------------

cursor-color = #1b1f24
cursor-text = #ffffff

# +----------------------------------------------------------------------------
# | Selection
# +----------------------------------------------------------------------------
# |
# | Colors used for highlighted/selected text.
# |
# +----------------------------------------------------------------------------

selection-background = #cee1f8
selection-foreground = #1b1f24
