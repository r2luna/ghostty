# +----------------------------------------------------------------------------
# | Pinnord — Dark Theme
# +----------------------------------------------------------------------------
# |
# | Dark gray theme with subtle blue (Nord) tones. Colors match the Neovim
# | pinnord.nvim palette so the editor and terminal stay in sync.
# |
# +----------------------------------------------------------------------------

# +----------------------------------------------------------------------------
# | ANSI Palette (16 colors)
# +----------------------------------------------------------------------------
# |
# | Indices 0-7 are the normal colors, 8-15 the bright variants, in the order
# | black, red, green, yellow, blue, magenta, cyan, white.
# |
# +----------------------------------------------------------------------------

palette = 0=#1a1c21
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0
palette = 8=#4c566a
palette = 9=#bf616a
palette = 10=#a3be8c
palette = 11=#ebcb8b
palette = 12=#81a1c1
palette = 13=#b48ead
palette = 14=#8fbcbb
palette = 15=#eceff4

# +----------------------------------------------------------------------------
# | Background & Foreground
# +----------------------------------------------------------------------------
# |
# | Base terminal background and default text color.
# |
# +----------------------------------------------------------------------------

background = #0A0A0A
foreground = #d8dee9

# +----------------------------------------------------------------------------
# | Cursor
# +----------------------------------------------------------------------------
# |
# | Cursor fill color and the color of the glyph under the cursor.
# |
# +----------------------------------------------------------------------------

cursor-color = #eceff4
cursor-text = #1a1c21

# +----------------------------------------------------------------------------
# | Selection
# +----------------------------------------------------------------------------
# |
# | Colors used for highlighted/selected text.
# |
# +----------------------------------------------------------------------------

selection-background = #5e81ac
selection-foreground = #d8dee9

# +----------------------------------------------------------------------------
# | Dark-only Transparency
# +----------------------------------------------------------------------------
# |
# | Living inside the dark theme so only dark mode is translucent; the light
# | theme stays fully opaque. Blur radius is set in the main config.
# |
# +----------------------------------------------------------------------------

background-opacity = 0.8
background-blur = macos-glass-regular
